<mxfile host="app.diagrams.net" modified="2026-07-20T00:00:00.000Z" agent="Codex" version="24.7.17"><diagram id="prms-tsm-use-case" name="Use Case Diagram"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="2400" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="system" value="ระบบบริหารจัดการทะเบียนสุนัขและแมว เทศบาลท่าโพธ์ (PRMS-TSM)" style="swimlane;html=1;startSize=42;horizontal=1;rounded=0;collapsible=0;fontFamily=Tahoma;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="280" y="60" width="1420" height="2130" as="geometry" /></mxCell><mxCell id="actor_staff" value="เจ้าหน้าที่เทศบาล" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontFamily=Tahoma;fontSize=16;" vertex="1" parent="1"><mxGeometry x="70" y="930" width="90" height="170" as="geometry" /></mxCell><mxCell id="actor_owner" value="เจ้าของสัตว์เลี้ยง" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontFamily=Tahoma;fontSize=16;" vertex="1" parent="1"><mxGeometry x="1820" y="930" width="100" height="170" as="geometry" /></mxCell><mxCell id="uc1" value="UC1  เข้าสู่ระบบเว็บไซต์เจ้าหน้าที่" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#FFF2CC;strokeColor=#D6A52B;fontFamily=Tahoma;fontSize=14;" vertex="1" parent="system"><mxGeometry x="90" y="75" width="540" height="88" as="geometry" /></mxCell><mxCell id="edge1" style="endArrow=none;html=1;rounded=0;strokeColor=#666666;" edge="1" parent="1" source="actor_staff" target="uc1"><mxGeometry x="0" y="0" width="0" height="0" as="geometry" relative="1" /></mxCell><mxCell id="uc2" value="UC2  ยืนยันตัวตนผ่าน LINE" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#FFF2CC;strokeColor=#D6A52B;fontFamily=Tahoma;fontSize=14;" vertex="1" parent="system"><mxGeometry x="90" y="207" width="540" height="88" as="geometry" /></mxCell><mxC