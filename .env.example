# ==========================================================
# PRMS-TSM Environment Configuration
# คัดลอกไฟล์นี้เป็น .env ก่อนใช้งาน
# ห้ามอัปโหลดไฟล์ .env จริงขึ้น GitHub
# ==========================================================

NODE_ENV=development
PORT=4100

# เว็บไซต์ที่อนุญาตให้เรียก API
ADMIN_WEB_ORIGIN=http://localhost:5173
CITIZEN_WEB_ORIGIN=http://localhost:5174
PUBLIC_WEB_ORIGIN=https://0tyght.github.io

# MySQL / MariaDB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=prms_tsm
DB_USER=root
DB_PASSWORD=

# Production ต้องใช้ค่าสุ่มยาวอย่างน้อย 32 ตัวอักษร
JWT_SECRET=

# LINE Integration
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_LIFF_ID=